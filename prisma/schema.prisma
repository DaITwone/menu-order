generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
}

model Invoice {
  id            String        @id @default(cuid())
  code          String        @unique
  note          String        @default("")
  items         Json
  total         Int
  paymentMethod PaymentMethod @default(CASH)
  createdAt     DateTime      @default(now())

  @@index([createdAt])
}
